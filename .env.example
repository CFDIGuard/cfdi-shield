APP_NAME=CFDI Shield
APP_VERSION=1.0
DEBUG=False
PORT=8000
BASE_URL=http://127.0.0.1:8000
APP_SECRET_KEY=change-this-in-production
DATABASE_URL=sqlite:///./facturas.db
ENABLE_REGISTRATION=True
ENABLE_BETA_MODE=False
BETA_ACCESS_CODE=
BETA_ALLOWED_EMAILS=
DEMO_MODE=False
ALLOW_REAL_XML_UPLOAD=True
AUTH_RATE_LIMIT_WINDOW_SECONDS=900
AUTH_RATE_LIMIT_IP_MAX_ATTEMPTS=10
AUTH_RATE_LIMIT_USER_MAX_ATTEMPTS=5
ENABLE_SAT_VALIDATION=True
SAT_TIMEOUT_SECONDS=10
SAT_CACHE_TTL_SECONDS=21600
ENABLE_EXCHANGE_RATE_API=True
EXCHANGE_RATE_API_URL=https://api.frankfurter.dev
EXCHANGE_RATE_TIMEOUT_SECONDS=5
BANK_RECONCILIATION_AMOUNT_TOLERANCE=1.00
BANK_RECONCILIATION_DATE_WINDOW_DAYS=5
MASTER_ENCRYPTION_KEY=change-this-too
ENABLE_2FA=True
LOCAL_MODE=False
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=usuario@example.com
SMTP_PASSWORD=change-this
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_USE_TLS=True
SMTP_USE_SSL=False
MAX_UPLOAD_SIZE_BYTES=5242880
MAX_FILES_PER_UPLOAD=20
