APP_NAME=CFDI Shield
APP_VERSION=1.0
DEBUG=False
PORT=8000
BASE_URL=http://127.0.0.1:8000
APP_SECRET_KEY=change-this-in-production
DATABASE_URL=sqlite:///./facturas.db
ENABLE_SAT_VALIDATION=True
SAT_TIMEOUT_SECONDS=10
SAT_CACHE_TTL_SECONDS=21600
MASTER_ENCRYPTION_KEY=change-this-too
ENABLE_2FA=True
LOCAL_MODE=False
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=usuario@example.com
SMTP_PASSWORD=change-this
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_USE_TLS=True
SMTP_USE_SSL=False
MAX_UPLOAD_SIZE_BYTES=5242880
MAX_FILES_PER_UPLOAD=20
